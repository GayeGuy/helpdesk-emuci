# Copier vers .env et adapter
PORT=3001
# PostgreSQL / Neon. Si absent → stockage JSON local (dev/tests).
# postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/helpdesk?sslmode=require
DATABASE_URL=
# Secret JWT — CHANGER en production (chaîne aléatoire longue)
JWT_SECRET=dev-change-me-please-use-a-long-random-string
# Durée de vie de l'access token
JWT_TTL=15m
# Durée de vie du refresh token
REFRESH_TTL=7d
# Origine autorisée pour CORS (frontend Vite)
CORS_ORIGIN=http://localhost:5173
